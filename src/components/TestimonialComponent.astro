---

import TestimonialCardTemplate from "./TestimonialCardTemplate.astro"

const count = 5;
---

<section>
    <p>Aus meinen</p>
    <h2>Testimonial</h2>

    <div class="grid-template">
        <div>
            <p>Was gute Arbeit ist, darüber lässt sich streiten. Aber ob jemand zuverlässig ist und ehrlich mit dir umgeht, das merkt man schnell. Hier ist, was meine Kollegen dazu sagen:</p>
        </div>

        <div class="carousel-container">
            <div class="card-carousel-wrapper">
                {Array.from({ length: count }, (_, i) => (
                    <div class="card-slide" data-index={i}>
                        <TestimonialCardTemplate />
                    </div>
                ))}
            </div>

            <div class="dots" role="tablist">
                {Array.from({ length: count }, (_, i) => (
                    <button
                        class:list={["dot", { active: i === 0 }]}
                        data-index={i}
                        aria-label={`Testimonial ${i + 1}`}
                        role="tab"
                    />
                ))}
            </div>
        </div>
    </div>
</section>

<script>
    const wrapper = document.querySelector(".card-carousel-wrapper") as HTMLElement;
    const dots = document.querySelectorAll<HTMLElement>(".dot");
    const slides = wrapper.querySelectorAll<HTMLElement>(".card-slide");

    function updateDots() {
        const wrapperLeft = wrapper.getBoundingClientRect().left;
        let closest = 0;
        let minDist = Infinity;
        slides.forEach((slide, i) => {
            const dist = Math.abs(slide.getBoundingClientRect().left - wrapperLeft);
            if (dist < minDist) { minDist = dist; closest = i; }
        });
        dots.forEach((d) => d.classList.remove("active"));
        dots[closest]?.classList.add("active");
    }

    dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
            slides[i].scrollIntoView({ behavior: "smooth", block: "nearest", inline: "start" });
        });
    });

    wrapper.addEventListener("scroll", updateDots, { passive: true });
</script>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section {
        box-sizing: border-box;
        padding: 96px $inner-padding;
        background-color: $grey-background;
    }

    p {
        max-width: 55ch;
    }

    .grid-template {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1rem;
        align-items: start;

        @media (max-width: 768px) {
            grid-template-columns: 1fr;
        }
    }

    .carousel-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .card-carousel-wrapper {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        gap: 1rem;

        &::-webkit-scrollbar {
            display: none;
        }
    }

    .card-slide {
        flex: 0 0 calc(50% - 0.5rem);
        scroll-snap-align: start;
        display: flex;
        justify-content: center;

        @media (max-width: 768px) {
            flex: 0 0 100%;
        }
    }

    .dots {
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    .dot {
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        border: none;
        background-color: #D9D9D9;
        cursor: pointer;
        transition: background-color 0.2s ease, transform 0.2s ease;
        padding: 0;

        &.active {
            background-color: $main-color;
            transform: scale(1.3);
        }
    }
</style>
