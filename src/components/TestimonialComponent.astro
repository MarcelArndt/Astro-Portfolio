---
import TestimonialCardTemplate from "./TestimonialCardTemplate.astro";
import Text from "../data/testimonial.json";
const cardMaxWidth:number = 372;
const cardMinWidth:number = 260;
---

<section>
    <p>Aus meinen</p>
    <h2>Testimonial</h2>

    <div class="layout">
        <div class="flow-text">
            <p>Was gute Arbeit ist, darüber lässt sich streiten. Aber ob jemand zuverlässig ist und ehrlich mit dir umgeht, das merkt man schnell. Hier ist, was meine Kollegen dazu sagen:</p>
        </div>

        <div class="carousel-area">
           
            <div class="carousel-inside-wrapper" style={{"--card-width": `clamp(${cardMinWidth}px, 36vw, ${cardMaxWidth}px)`}}>
                {Text.map((item, i) => (
                    <div class="card-card" data-index={i}>
                        <TestimonialCardTemplate text={item.text} name={item.name} position={item.position} cardMinWidth={cardMinWidth} cardMaxWidth={cardMaxWidth}/>
                    </div>
                ))}
            </div>

            <div class="dots">
                {Text.map((_, i) => (
                    <button class:list={["dot", { active: i === 0 }]} data-index={i} aria-label={`Testimonial ${i + 1}`} />
                ))}
            </div>

            <div class="carousel-nav">
                <ul>
                    <li><button previous-button aria-label="Vorherige Karte"><span><img loading="lazy" alt="" src="./assets/icons/ui/goggle-mat-arrow-forward-ios.svg" /></span></button></li>
                    <li><button next-button aria-label="Nächste Karte"><span><img loading="lazy" alt="" src="./assets/icons/ui/goggle-mat-arrow-forward-ios.svg" /></span></button></li>
                </ul>
            </div>

        </div>
    </div>
</section>

<script>

    const cards = Array.from(document.querySelectorAll<HTMLElement>('.card-card'));
    const carouselInsideWrapper = document.querySelector<HTMLElement>('.carousel-inside-wrapper')
    const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
    const middleOfCardsLenght = Math.floor(cards.length / 2)
    const previousButton = document.querySelector<HTMLButtonElement>('[previous-button]');
    const nextButton = document.querySelector<HTMLButtonElement>('[next-button]');

    function init(){
        scrollTocard(middleOfCardsLenght, false);
        checkDotPosition();
        setButtons();
    }

    function scrollTocard(index: number, smooth = true) {
        cards[index].scrollIntoView({ behavior: smooth ? 'smooth' : 'instant', block: 'nearest', inline: 'center' });
        setActiveDot(index)
    }

    function setActiveDot(index: number) {
        dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
    }

    dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
            scrollTocard(i);
        });
    });

    function getActiveIndex(){
         if(!carouselInsideWrapper || !cards) return 0;
            const cardWidth = cards[0].getBoundingClientRect().width;
            const scrollLeft =  carouselInsideWrapper.scrollLeft; 
            const activeIndex = Math.round((scrollLeft) / cardWidth);
        return activeIndex || 0;
    }

    function checkDotPosition(){
         if(!carouselInsideWrapper || !cards) return;
         carouselInsideWrapper.addEventListener('scroll', () => {
            setActiveDot(getActiveIndex());
            checkButtons();
         });
    }

    function findIndexForButtons(){
        const nextIndex = getActiveIndex() + 1 >= cards.length? null : getActiveIndex() + 1;
        const previousIndex =  getActiveIndex() - 1 >= 0? getActiveIndex() - 1 : null ;
        return {nextId : nextIndex, previousId: previousIndex}
    }

    function setButtons(){
        previousButton?.addEventListener('click', (event)=> {
            event.preventDefault();
            const previousId = findIndexForButtons().previousId
            if(previousId !== null){
                scrollTocard(previousId, true)
            }

        });

        nextButton?.addEventListener('click', (event)=> {
            event.preventDefault();
            const nextId = findIndexForButtons().nextId
            if(nextId){
                scrollTocard(nextId, true)
            }
        });
    }

    function checkButtons() {
      const { nextId, previousId } = findIndexForButtons();
            if (nextButton) nextButton.disabled = nextId === 
        null;
            if (previousButton) previousButton.disabled =    
        previousId === null;
  }

    init()

</script>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section {
        box-sizing: border-box;
        padding: 96px $inner-padding;
        background-color: $grey-background;

    }

    .layout {
        display: flex;
        flex-direction: column;
        gap: 4.5rem;
    }

    .flow-text p {
        max-width: 42ch;
    }

    .carousel-area {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    .carousel-inside-wrapper {
        box-sizing: border-box;
        display: flex;
        overflow-x: scroll;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        gap: 1.75rem;
        padding: 1rem 0;
        scrollbar-width: none;
        padding-inline: calc(50% - (calc(var(--card-width))  / 2));
        scroll-padding-inline: calc(50% - (var(--card-width) / 2));
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 18%,
            black 82%,
            transparent 100%
        );

        &::-webkit-scrollbar {
             display: none;
        }

        @media screen and (max-width: 600px) {
            mask-image: linear-gradient(
                to right,
                transparent 0%
                black 0%,
                black 100%,
                transparent 100%
            );
        }
    }


    .dots {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
    }

    .dot {
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 50%;
        border: none;
        background-color: #D9D9D9;
        cursor: pointer;
        padding: 0;
        transition: background-color 0.25s ease, transform 0.25s ease;

        &.active {
            background-color: $main-color;
            transform: scale(1.5);
        }
    }

    .carousel-nav{
        ul{
            width: 100%;
            display: flex;
            list-style: none;
            justify-content: center;
            align-items: center;
            gap: 1rem;

        }

        button{
            display: flex;
            align-items: center;
            justify-content: center;    
            width: 48px;
            aspect-ratio:  1 / 1;
            flex-shrink: 0;
            background-color: #171622;
            border: 2px solid #24283A;
            border-radius: 50%;
            padding: 0px;

            span{
                display: flex;
                align-items: center;
                justify-content: center;
                padding-left: 3px;
                filter: saturate(0%) brightness(1000%);
                opacity: 0.5;   
            }

            &:disabled{
                opacity: 0.25;
            }

            &:not(:disabled):hover{
                border-color: white;
                scale: 1; 

                span{
                    opacity: 1; 
                }
            }
        }
        
        li:first-child{
            scale: (-1);
        }
    }

</style>
