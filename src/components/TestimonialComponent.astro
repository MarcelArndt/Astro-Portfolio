---
import TestimonialCardTemplate from "./TestimonialCardTemplate.astro"
import Text from "../data/testimonial.json"
---

<section>
    <p>Aus meinen</p>
    <h2>Testimonial</h2>

    <div class="layout">
        <div class="flow-text">
            <p>Was gute Arbeit ist, darüber lässt sich streiten. Aber ob jemand zuverlässig ist und ehrlich mit dir umgeht, das merkt man schnell. Hier ist, was meine Kollegen dazu sagen:</p>
            
        </div>

        <div class="carousel-area">
           
            <div class="carousel-viewport">
                {Text.map((item, i) => (
                    <div class="card-slide" data-index={i}>
                        <TestimonialCardTemplate text={item.text} name={item.name} position={item.position} />
                    </div>
                ))}
            </div>

            <div class="dots">
                {Text.map((_, i) => (
                    <button class:list={["dot", { active: i === 0 }]} data-index={i} aria-label={`Testimonial ${i + 1}`} />
                ))}
            </div>
        </div>
    </div>
</section>

<script>

    const slides = Array.from(document.querySelectorAll<HTMLElement>('.card-slide'));
    const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
    const middle = Math.floor(slides.length / 2)

    function scrollToSlide(index: number, smooth = true) {
        slides[index].scrollIntoView({ behavior: smooth ? 'smooth' : 'instant', block: 'nearest', inline: 'center' });
        setActiveDot(index)
    }

    function setActiveDot(index: number) {
        dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
    }


    dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
            scrollToSlide(i);
        });
    });



    scrollToSlide(middle, false);
</script>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section {
        box-sizing: border-box;
        padding: 96px $inner-padding;
        background-color: $grey-background;

    }

    .layout {
        display: flex;
        flex-direction: column;
        gap: 4.5rem;
    }

    .flow-text p {
        max-width: 55ch;
    }

    .carousel-area {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
    }

    .carousel-viewport {
        box-sizing: border-box;
        --card-width: 320px;
        display: flex;
        overflow-x: scroll;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        gap: 1.75rem;
        padding: 1rem 0;
        scrollbar-width: none;
        padding-inline: calc(50% - calc(var(--card-width) / 2));
        scroll-padding-inline: calc(50% - 160px);

       

        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 18%,
            black 82%,
            transparent 100%
        );

        &::-webkit-scrollbar {
             display: none;
            }
    }

    .card-slide {
        flex: 0 0 320px;
        scroll-snap-align: center;
    }


    .dots {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
    }

    .dot {
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 50%;
        border: none;
        background-color: #D9D9D9;
        cursor: pointer;
        padding: 0;
        transition: background-color 0.25s ease, transform 0.25s ease;

        &.active {
            background-color: $main-color;
            transform: scale(1.5);
        }
    }
</style>
