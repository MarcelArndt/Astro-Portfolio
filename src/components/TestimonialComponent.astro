                            </svg>
                        </a>
                    </li>
                </ul>
            </div>
        </div>


        <div class="carousel-area" role="region" aria-label="Testimonials" testimonial-carousel-section>

            <div class="carousel-inside-wrapper" testimonial-carousel tabindex="0" style={{"--card-width": `clamp(${cardMinWidth}px, 36vw, ${cardMaxWidth}px)`}}>
                {Text.map((item, i) => (
                    <div class="card-card" data-index={i}>
                        <TestimonialCardTemplate text={item.text} name={item.name} position={item.position} cardMinWidth={cardMinWidth} cardMaxWidth={cardMaxWidth}/>
                    </div>
                ))}
            </div>

            <div class="dots">
                {Text.map((_, i) => (
                    <button class:list={["dot", { active: i === 0 }]} data-index={i} aria-label={`Testimonial ${i + 1}`} />
                ))}
            </div>

            <div class="carousel-nav">
                <ul>
                    <li><button previous-button aria-label="Vorherige Karte"><span><img loading="lazy" alt="" src="./assets/icons/ui/goggle-mat-arrow-forward-ios.svg" /></span></button></li>
                    <li><button next-button aria-label="Nächste Karte"><span><img loading="lazy" alt="" src="./assets/icons/ui/goggle-mat-arrow-forward-ios.svg" /></span></button></li>
                </ul>
            </div>

        </div>

</section>


<script>

    const testimoinalCards = Array.from(document.querySelectorAll<HTMLElement>('[testimoinal-card]'));
    const cardWrappers = Array.from(document.querySelectorAll<HTMLElement>('.card-card'));
    const carouselInsideWrapper = document.querySelector<HTMLElement>('.carousel-inside-wrapper')
    const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
    const middleOfCardsLenght = Math.floor(testimoinalCards.length / 2)
    const previousButton = document.querySelector<HTMLButtonElement>('[previous-button]');
    const nextButton = document.querySelector<HTMLButtonElement>('[next-button]');
    let currentIndex = middleOfCardsLenght;

    function init(){
        scrollToCard(middleOfCardsLenght, false);
        checkDotPosition();
        setButtons();
        carouselInsideWrapper?.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowLeft') {
                event.preventDefault();
                const previousId = findIndexForButtons().previousId;
                if (previousId !== null) scrollToCard(previousId, true);
            } else if (event.key === 'ArrowRight') {
                event.preventDefault();
                const nextId = findIndexForButtons().nextId;
                if (nextId !== null) scrollToCard(nextId, true);
            }
        });
    }

    function scrollToCard(index: number, smooth = true) {
        currentIndex = index;
        testimoinalCards[index].scrollIntoView({ behavior: smooth ? 'smooth' : 'instant', block: 'nearest', inline: 'center' });
        setActiveDot(index);
        setCardToActive(index)
    }

    function setActiveDot(index: number) {
        dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
    }

    function setCardToActive(index: number){
        cardWrappers.forEach((card, cardIndex) => {
            card.classList.toggle('active', cardIndex === index);
            card.classList.toggle('small', cardIndex < index - 1 || cardIndex > index + 1);
        });
    }

    dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
            scrollToCard(i);
        });
    });

    function getActiveIndex(){
        if(!carouselInsideWrapper || !cardWrappers.length) return 0;
        const cardWidth = cardWrappers[0].offsetWidth;
        const gap = parseFloat(getComputedStyle(carouselInsideWrapper).gap) || 0;
        const scrollLeft = carouselInsideWrapper.scrollLeft;
        const activeIndex = Math.round(scrollLeft / (cardWidth + gap));
        return activeIndex || 0;
    }

    function checkDotPosition(){
        if(!carouselInsideWrapper || !testimoinalCards) return;
        carouselInsideWrapper.addEventListener('scroll', () => {
            const index = getActiveIndex();
            currentIndex = index;
            setActiveDot(index);
            checkButtons();
            setCardToActive(index);     
           
        });
    }

    function findIndexForButtons(){
        const nextIndex = currentIndex + 1 >= testimoinalCards.length ? null : currentIndex + 1;
        const previousIndex = currentIndex - 1 >= 0 ? currentIndex - 1 : null;
        return {nextId: nextIndex, previousId: previousIndex}
    }

    function setButtons(){
        previousButton?.addEventListener('click', (event)=> {
            event.preventDefault();
            const previousId = findIndexForButtons().previousId
            if(previousId !== null){
                scrollToCard(previousId, true)
            }

        });

        nextButton?.addEventListener('click', (event)=> {
            event.preventDefault();
            const nextId = findIndexForButtons().nextId
            if(nextId){
                scrollToCard(nextId, true)
            }
        });
    }

    function checkButtons() {
      const { nextId, previousId } = findIndexForButtons();
            if (nextButton) nextButton.disabled = nextId === 
        null;
            if (previousButton) previousButton.disabled =    
        previousId === null;
  }

    init()


    // GSAP
    import { gsap } from "../lip/gsap";

    const testimonialSection = document.querySelector<HTMLElement>(`[testimonial-section]`);
    const testimonialText = gsap.utils.toArray(document.querySelectorAll<HTMLElement>(`[testimonial-text]`));
    const socialIcons = gsap.utils.toArray(document.querySelectorAll<HTMLElement>(`[testimonial-icon]`));
    const redTestimonialCurtain = document.querySelector<HTMLElement>(`[red-testimonial-curtain]`);
    const whiteTestimonialCurtain = document.querySelector<HTMLElement>(`[white-testimonial-curtain]`);
    
        const MainContentTl = gsap.timeline({
        scrollTrigger: {
            id: 'testimonial-section',
            trigger: testimonialSection,
            start: 'top 50%',
            end: '33% 56%',
            scrub: 1,
    } });

    MainContentTl
    .from(testimonialText,{
        opacity:0,
        y:"+=100px",
        stagger: 0.5,
    })
    .from(socialIcons,{
        opacity:0,
        y:"+=100px",
        stagger: 0.5,
    },"+=0.05")
    .from(testimoinalCards,{
        opacity:0,
        y:"+=75px",
        stagger: {
            from: "start",
            amount: 0.75
        }
    },"-=0.3")

    const TestimonialCurtainTL = gsap.timeline({
        scrollTrigger: {
            id: 'testimonial-curtain',
            trigger: testimonialSection,
            start: '70% 75%',
            end: 'bottom 50%',
            scrub: 1,
    } });

    TestimonialCurtainTL
    .to(redTestimonialCurtain,{
        y:"-110vh",
        ease: "power4.out",
    })
    .to(whiteTestimonialCurtain,{
        y:"-100vh",
        ease: "power1.out",
    },"<")

</script>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section {
        box-sizing: border-box;
        padding: 96px $inner-padding;
        background-color: $grey-background;
        padding-bottom: 480px;
        width: 100%;
        position: relative;
    }

    .vertical-line {
        border: none;
        width: 1px;
        height: 256px;
        opacity: 0.6;
        background-color: #fff;
        margin: 0 6rem;
        @media screen and (max-width:1440px) {
            width: 100%;
            height: 1px;
            margin: 1rem 0;
            max-width: 66ch;
        }
    }

    .testimonial-text-wrapper{
        display: flex;
        width: 100%;
        align-items: end;
        margin-bottom: 3rem;
        @media screen  and (max-width:1440px){
            flex-direction: column;
            align-items: start;
            gap: 2rem;
            margin-bottom: 0rem;
        }
    }

    .icon-wrapper{
        height: 256px;
        box-sizing: border-box;
        display: flex;
        align-items: start;
        justify-content: center;
        flex-direction: column;
        gap: 0.35rem;
        strong{
            display: block;
            width: 100%;
            color:#fff;
            font-size: $font-size-200;
            font-weight: 300;
        }

        p{
            opacity: 0.6;
        }
        ul{
            margin-top: 0.35rem;
            list-style: none;
            display: flex;
            gap: 1.5rem;
        }

        a{
            &:hover{
                svg{
                   opacity: 1;
                }
            }
        }

        svg{
            fill:#fff;
            height: 48px;
            width:48px;
            opacity: 0.6;
            transition: opacity 0.25s ease-in-out;
        }

        @media screen and (max-width:1440px) {
            height: auto;
        }
    }

    .layout {
        display: flex;
        flex-direction: column;
        gap: 4.5rem;
    }

    .flow-text p {
        max-width: 42ch;
    }

    .carousel-area {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    .carousel-inside-wrapper {
        box-sizing: border-box;
        display: flex;
        overflow-x: scroll;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        gap: 3rem;
        padding: 1rem 0;
        scrollbar-width: none;
        padding-inline: calc(50% - (calc(var(--card-width))  / 2));
        scroll-padding-inline: calc(50% - (var(--card-width) / 2));
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 18%,
            black 82%,
            transparent 100%
        );

        &::-webkit-scrollbar {
             display: none;
        }

        @media screen and (max-width: 600px) {
            mask-image: none;
        }
    }


    .dots {
        margin-top: 0.5rem;
        display: flex;
        justify-content: center;
        gap: clamp(1.5rem, 3vw, 1.75rem);
    }

    .dot {
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        border: none;
        background-color: #D9D9D9;
        cursor: pointer;
        padding: 0;
        transition: background-color 0.25s ease, transform 0.25s ease;

        &:hover{
            scale: 1.25;
        }

        &.active {
            background-color: $main-color;
            transform: scale(1.5);

         &:hover{
            cursor: auto;
            scale: 1;
            }
        }
    }

    .carousel-nav{
        ul{
            width: 100%;
            display: flex;
            list-style: none;
            justify-content: center;
            align-items: center;
            gap: clamp(1rem, 4vw, 2rem);

        }

        button{
            display: flex;
            align-items: center;
            justify-content: center;    
            width: clamp(48px, 4vw, 56px);
            aspect-ratio:  1 / 1;
            flex-shrink: 0;
            background-color: #171622;
            border: 2px solid #24283A;
            border-radius: 50%;
            padding: 0px;

            span{
                display: flex;
                align-items: center;
                justify-content: center;
                padding-left: 3px;
                filter: saturate(0%) brightness(1000%);
                opacity: 0.5;  
                

            }

            &:disabled{
                opacity: 0.25;
            }

            &:not(:disabled):hover{
                border-color: white;
                scale: 1; 

                span{
                    opacity: 1; 
                }
            }
        }
        
        li:first-child{
