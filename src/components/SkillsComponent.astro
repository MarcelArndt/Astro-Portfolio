---
---
<section skill-section id="skills">
    <div class="content-box">

        <div picture-container class="picture-container"> 
            <img picture-content src="./assets/pictures/vs-background.webp">
        </div>

        <div class="textblock" text-block>  
            <div skill-section-box>            
                <p>Dies sind</p>      
                <h2>Meine Skills</h2>
            </div>

        <div skill-section-box class="skill-category-wrapper">
                <h3>Frontend</h3>
                <div class="skill-category-container">
                    <ul frontend-stack >
                        <li><img src="./assets/icons/technology/angular.svg">Angular</li>
                        <li><img src="./assets/icons/technology/astro.svg">Astro</li>
                        <li><img src="./assets/icons/technology/javascript.svg">JavaScript</li>
                        <li><img src="./assets/icons/technology/typescript.svg">TypeScript</li>
                        <li><img src="./assets/icons/technology/gsap.png">GSAP</li>
                        <li><img src="./assets/icons/technology/sass.svg">SASS</li>
                    </ul>
                </div>
            </div>

            <div skill-section-box class="skill-category-wrapper">
                <h3>Backend</h3>
                <div class="skill-category-container">
                    <ul backend-stack >
                        <li><img src="./assets/icons/technology/django.svg">Django</li>
                        <li><img src="./assets/icons/technology/python.svg">Python</li>
                        <li><img src="./assets/icons/technology/firebase.svg">Firebase</li>
                    </ul>
                </div>
            </div>

            <div skill-section-box class="skill-category-wrapper">
                <h3>Tools</h3>
                <div class="skill-category-container">
                    <ul tools-stack >
                        <li><img src="./assets/icons/technology/figma.svg">Figma</li>
                        <li><img src="./assets/icons/technology/git.svg">Git</li>
                        <li><img src="./assets/icons/technology/docker.svg">Docker</li>
                    </ul>
                </div>
            </div>

            <div skill-section-box>
                <p> Du vermisst eine bestimmte Technologie in meinem Stack?<br>Ich bin offen für neue Tools und lerne schnell dazu.</p>
            </div>
             <div skill-section-box>
                <button>Schreib mir</button>
            </div>
    </div>
</section>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section{
        width: 100%;
        background-color: $grey-background;
        padding: 124px 0px;
        position: relative;
        z-index: 300;
    }

    .content-box{
        width: 100%;
        height: 100%;
        display: flex;
        align-items: start;
        padding: 0px 6rem;
        box-sizing: border-box;

        @media screen and (max-width:1020px) {
        padding: 0px 2rem;
        text-align: center;
        justify-content: center;
        }
    }

    .textblock{
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .skill-category-wrapper{
        display: grid;
        margin: 4rem 0rem;
        grid-template-columns: 250px 1fr;

        @media screen and (max-width:1020px) {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        

        h3{
            color: #ffffff;
            width: max-content;

        }
    }

    button{
        color: white;
    }

    .skill-category-container{
        width: 100%;
        display: flex;

        @media screen and (max-width:1020px) {
            justify-content: center;
            margin-top: 3rem;
        }
    }

    .skill-category-container ul{
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        row-gap: 3.5rem;
        gap: 3.5rem;

        @media screen and (max-width:1020px) {
            padding-left: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
        }
    }


    .skill-category-container li{
        display: flex;
        align-items: center;
        color:white;
        font-size: $font-size-200;
        box-sizing: border-box;
        line-height: 2.5rem;

        img{
            margin-right: 1rem;
            max-height: 43px;
            width: 43px;
            object-position: center;
        }
    }
    .picture-container{
        width: 50%;
        position: absolute;
        right: 0px;
        top: 0px;
        height: 100%;
        overflow: hidden;
        opacity: 0.4;

        img{
  
            filter: blur(6px);
        }

    }

</style>

<script>
    import { gsap } from "../lip/gsap";

    const skillSection = document.querySelector<HTMLElement>("[skill-section]");
    const sectionBoxes = gsap.utils.toArray("[skill-section-box]");
    const textBox = document.querySelector<HTMLElement>("[text-block]");
    const pictureContent = document.querySelector<HTMLElement>("[picture-content]");

    gsap.set(textBox,{
        y:"-=20%",
    })

    gsap.set(pictureContent,{
        y:"+=55%",
        x: "+=1050px",
        opacity:0,
    })

    const tlTextbox = gsap.timeline({
        scrollTrigger: {
            trigger: skillSection,
            start: "top 75%",
            end:"95% bottom",
            scrub:1,
            toggleActions: "play none none none",
        },
    });

    tlTextbox.to(textBox,{
        y:"+=20%"
    })


    const tlImage = gsap.timeline({
    scrollTrigger: {
        trigger: skillSection,
        start: "top 50%",
        end:"95% bottom",
        scrub:1,
        toggleActions: "play none none none",
        },
    });

    tlImage.to(pictureContent ,{
        x:"-=1045px",
        opacity:1,
    })
    .to(pictureContent,{
        y:"-=33%"
    })

    const tlOne = gsap.timeline({
        scrollTrigger: {
            trigger: skillSection,
            start: "top 65%",
            end:"bottom bottom",
            scrub:1,
            toggleActions: "play none none none",

        },
    });

    (sectionBoxes as HTMLElement[]).forEach((section, i) => {

    tlOne.from(section, {
        opacity: 0,
        y: "+=70",
        ease: "power2.out"
    })

    const lis = section.querySelectorAll('.skill-category-wrapper ul li');
    if (lis.length > 0) {
        tlOne.from(lis, {
        opacity: 0,
        y: "+=70",
        stagger: 1,
        ease: "power2.out"
        }, ">");
    }
    })

</script>