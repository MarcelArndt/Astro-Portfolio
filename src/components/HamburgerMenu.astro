<div class="hamburger-menu-wrapper">
    <input name="menu-checkbox" type="checkbox" class="hamburger-menu-checkbox" id="menu-checkbox">
    <label class="hamburger-menu-icon" for="menu-checkbox" aria-label="Navigation öffnen" role="button">
        <div class="sr-only">Navigation öffnen</div>
        <span></span>
        <span></span>
        <span></span>
    </label>
    
    <nav class="menu-content" id="menu-nav" aria-hidden="true">
        <div class="text-container" text-navi-container>
        <strong>Navigation:</strong>

        <!--  ADD MENU POINTS HERE   -->
          
        <ul navi-list>
            <li><a href="/#start" aria-label="Startseite">Start</a></li>
            <li><a href="/#about_me" aria-label="Über_mich">Über Mich</a></li>
            <li><a href="/#skills" aria-label="Skills">Skills</a></li>
            <li><a href="/#projects" aria-label="Projekte">Projekte</a></li>
            <li><a href="/#testimonial" aria-label="Testimonial">Testimonial</a></li>
            <li><a href="/#contact" aria-label="Kontakt">Kontakt</a></li>
        </ul>

        <div class="sub-navigation">
            <ul>
                <li><a href="/data-protection" aria-label="Datenschutz">Datenschutz</a></li>
                <li><a href="/imprint" aria-label="Impressum">Impressum</a></li>
            </ul>
        </div>

        </div>
    </nav>

    <div class="navi-curtain-wrapper" navi-curtain-wrapper>
        <div class="red-curtain" red-navi-curtain></div>
        <div class="white-curtain" white-navi-curtain></div>
    </div>
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .hamburger-menu-wrapper{

        --menu-icon-color:rgb(255, 255, 255);
        --menu-active-icon-color:#290509;
        --menu-background-curtain-infront-color:#fff;
        --menu-background-curtain-behint-color:#e44064;

        --nav-font-size: clamp(1.3rem, 5vw, 2rem);
        --headline-font-size: clamp(1.5rem, 5vw, 2.5rem);
        --headline-font-color: #e44064;
        --subline-font-size: clamp(1rem, 5vw, 1.125rem);
        --font-color:#290509;
        --hover-font-color:#e44064;
        --text-transform: uppercase;
        --hover-transformY:-2px;
        --hover-transformX:4px;
        --menu-max-width:1440px;

        position: relative;
        z-index: 999;
        align-items: center;
        height: 100%;
        aspect-ratio: 1 / 1;
        max-width: 64px;
    }


    .hamburger-menu-checkbox{
        position: absolute;
        z-index: 993;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;

        &:hover +.hamburger-menu-icon{
            transform: translate(1px,-2px);
            scale: 1.03;
        }

        &:checked + .hamburger-menu-icon {
            span{
                background-color:var(--menu-active-icon-color);
            }

            span:nth-of-type(1) { 
                transform: rotate(45deg) translate(12%,12%); 
                margin: 0px;
            }
            span:nth-of-type(2) { 
                opacity: 0; 
                margin: 0px;
            }
            span:nth-of-type(3) { 
                margin: 0px;
                transform: rotate(-45deg) translate(12%,12%); 
            }
        }

        &:checked ~ .menu-content{
            width: 100vw;
            pointer-events: all;
        }

        &:checked ~ .menu-content::before, &:checked ~ .menu-content::after{
            transform: translateX(0%);   
        }

        &:not(:checked) ~ .menu-content::before{
            transition: transform 0.50s cubic-bezier(.42,.1,.52,.97);
        }

        &:not(:checked) ~ .menu-content::after{
            transition: transform 0.45s ease-out;  
        }
    }

    .menu-content{
        pointer-events: none;
        position: fixed;
        z-index: 991;
        top: 0px;
        left: 0px;
        height: 100vh;
        width: 100vw;
        display: flex;
        justify-content: center;
        overflow: hidden;

        ul{
            width: 100%;
            padding-inline-start: 0px;
            margin-block-start: 0px;
            margin-block-end: 0px;
            list-style: none;

            @media screen and (max-width:800px) {
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            li a{
                display: block;
                font-size: var(--nav-font-size);
                color: var(--font-color);
                text-decoration: none;
                width: max-content;
                margin: 0.5rem 0px;
                text-transform: var(--text-transform);
                transition: color 0.25s ease-in-out, transform 0.125s ease-in-out;
                &:hover{
                    cursor: pointer;
                    color: var(--hover-font-color);
                    transform: translate(var(--hover-transformX),var(--hover-transformY));
                }
            }
        }
    }

    .hamburger-menu-icon{
        position: absolute;
        z-index: 992;
        top: 0px;
        left: 0px;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: transform 0.25s ease-in-out, scale 0.25s ease-in-out;

        span{
            margin: 5px;
            display: block;
            width: 34px;
            background-color: var(--menu-icon-color);
            height: 3px;
            transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out, margin 0.25s ease-in-out, background-color 0.5s ease-in;
        }

    }

    .text-container{
        pointer-events: none;
        width: 100%;
        height: 100%;
        max-width: var(--menu-max-width);
        display: flex;
        justify-content: center;
        flex-direction: column;
        box-sizing: border-box;
        opacity: 0;

        @media screen and (max-width:1600px){
            padding: 0px 3rem;
        }

        @media screen and (max-width:800px){
            padding: 0px 0rem;
            align-items: center;
        }
    }

    strong{
        font-size: var(--headline-font-size);
        color: var(--headline-font-color);
        text-transform: var(--text-transform);
        margin-bottom: 1rem;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .sub-navigation ul{
        margin-top: 2rem;
        display: flex;
        flex-direction: row;

        li:not(:first-child){
            margin-left: 1.5rem;
            position: relative;

            &::before{
                content: "";
                height: 50%;
                width: 2px;
                position: absolute;
                left: calc(1.5rem / 2 * -1);
                top: 50%;
                transform: translateY(-50%);
                background-color: var(--font-color);
            }
        }

        li a{
            font-size: var(--subline-font-size);
        }

    }

    .navi-curtain-wrapper{
        position: fixed;
        left: 0px;
        top: 0px;
        z-index: 900;
        width: 100%;
        height: 100vh;
        pointer-events: none;
    }

    .red-curtain{
        position: absolute;
        left: -100%;
        width: 100%;
        height: 100vh;
        background-color: $main-color;;
        pointer-events: none;
    }

    .white-curtain{
        position: absolute;
        left: -100%;
        width: 100%;
        height: 100vh;
        background-color: #fff;
        pointer-events: none;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', init)
    document.addEventListener('astro:page-load', init)
    const nav = document.getElementById('menu-nav');
    const checkbox = document.getElementById('menu-checkbox') as HTMLInputElement;

    function init(){
        document.getElementById('menu-nav')?.addEventListener('click', (e) => {
            closeMenu();
        });
        document.getElementById('menu-checkbox')?.addEventListener('click', toggleFixedBody);
    }

  function closeMenu() {
    if (!checkbox ) return;
    unlockScroll();
    nav?.setAttribute('aria-hidden', 'true');
    closeCurtain();
  }

  function toggleFixedBody(){
    if (!checkbox ) return;
    if(checkbox.checked){
        lockScroll();
        nav?.setAttribute('aria-hidden', 'false'); 
        openCurtain();
    }
    if(!checkbox.checked) {
        unlockScroll();
        nav?.setAttribute('aria-hidden', 'true');
        closeCurtain();
    }
    
  }

  function lockScroll() {
    document.body.style.overflow = 'hidden';
}

function unlockScroll() {
    document.body.style.overflow = '';
}

/* GSAP */
import { gsap } from "../lip/gsap";
import ScrollTrigger from "gsap/src/ScrollTrigger";
const redCurtain = document.querySelector<HTMLElement>('[red-navi-curtain]');
const whiteCurtain = document.querySelector<HTMLElement>('[white-navi-curtain]');
const textNaviContainer = document.querySelector<HTMLElement>('[text-navi-container]');
const naviCurtainWrapper =  document.querySelector<HTMLElement>('[navi-curtain-wrapper]');


whiteCurtain?.addEventListener("click", () => {
    closeCurtain();
});


function openCurtain(){
    checkbox.checked = true;
    gsap.killTweensOf(whiteCurtain);
    gsap.killTweensOf(redCurtain);
    gsap.killTweensOf(textNaviContainer);
    const curtainTl = gsap.timeline();
    curtainTl.to(redCurtain,{
        x:"100%",
        duration:0.25,
        ease: "power1.out",
    }).to(whiteCurtain,{
        x:"100%",
        duration:0.75,
        ease: "power4.out",
    },"<")
    .to(textNaviContainer ,{
        opacity:1,
        duration:0.25,
        onStart: () => { 
            gsap.set(textNaviContainer, { pointerEvents: "auto" });
            gsap.set(naviCurtainWrapper, { pointerEvents: "auto" });  
        },
    },"-=0.4")
}

function closeCurtain(){
    checkbox.checked = false;
    gsap.killTweensOf(whiteCurtain);
    gsap.killTweensOf(redCurtain);
    gsap.killTweensOf(textNaviContainer);
    const curtainTl = gsap.timeline();
    curtainTl.to(textNaviContainer ,{
        opacity:0,
        duration:0.15,
        onStart: () => {
            gsap.set(textNaviContainer, { pointerEvents: "none" }); 
            gsap.set(naviCurtainWrapper, { pointerEvents: "none" }); 
        },
    })
    .to(redCurtain,{
        x:"0%",
        duration:0.75,
        ease: "power4.out",
    })
    .to(whiteCurtain,{
        x:"0%",
        duration:0.25,
        ease: "power1.out",
        onComplete: () => ScrollTrigger.refresh(),
    },"<")
}

</script>