---
import ProjectListItem from "./ProjectListItem.astro"
import ProjectPreview from "./ProjectPreview.astro"
import projects from "../data/projects.json"
import projectPictureOne from "../../public/assets/pictures/projects/project_one.jpg"
import projectPictureTwo from "../../public/assets/pictures/projects/project_two.jpg"
import projectPictureThree from "../../public/assets/pictures/projects/project_three.jpg"
import projectPictureFour from "../../public/assets/pictures/projects/project_four.jpg"

const previewImageMap: Record<string, string> = {
    "project_one": projectPictureOne.src,
    "project_two": projectPictureTwo.src,
    "project_three": projectPictureThree.src,
    "project_four": projectPictureFour.src,
};
---

<section>
    <div class="project-section-wrapper" project-section id="projects">
        <div class="cirlce-window-wrapper">
            <div class="circle-wrapper">
                <div circle-curtain></div>
            </div>
        </div>

        <div class="content-box">
            <div>
                <p project-head-aera>Dies ist eine Auswahl</p>
                <h2 project-head-aera>Meine Projekte</h2>
                <p class="sub-text" project-head-aera>die meinen Weg sowie meine Leidenschaft für das Programmieren zeigt.</p>
            </div>

            <div>
                <ul class="projects-list">
                    {projects.map((project) => (
                        <ProjectListItem
                            {...project}
                            previewImageSrc={previewImageMap[project.previewImage]}
                        />
                    ))}
                </ul>
            </div>
        </div>
    </div>

    <div class="curtain-wrapper">
        <div class="black-box" project-curtain-black></div>
    </div>
</section>

<ProjectPreview />

<style lang="scss">
    @use "../styles/index.scss" as *;

    section {
        position: relative;
    }

    [project-section] {
        --background-color: #fff;
        --text-color: #320105;
        background-color: var(--background-color);

        p { color: var(--text-color); }
    }

    .project-section-wrapper {
        padding-bottom: 460px;
    }

    p {
        max-width: 75ch;
    }

    .sub-text {
        margin-bottom: 3rem;
    }

    .content-box {
        box-sizing: border-box;
        position: relative;
        z-index: 99;
        width: 100%;
        padding: 96px $inner-padding;
    }

    .projects-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .curtain-wrapper {
        position: absolute;
        top: -500px;
        left: 0px;
        width: 100%;
        height: calc(100% + 500px);
        overflow: hidden;
    }

    .black-box {
        z-index: 222;
        position: absolute;
        bottom: calc(-100% - 300px);
        height: 100%;
        width: 100%;
        background-color: $grey-background;

        &::before {
            content: "";
            position: absolute;
            top: -24%;
            right: 0px;
            width: 200%;
            height: 100%;
            rotate: 6deg;
            background-color: $grey-background;
        }
    }

    .cirlce-window-wrapper {
        position: fixed;
        width: 100%;
        height: 100%;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        left: 0px;
        top: 0px;
    }

    .circle-wrapper {
        width: 100%;
        height: 100%;
        max-width: 1920px;
        overflow: hidden;
        position: relative;
    }

    [circle-curtain] {
        --circle-color: #fff;
        z-index: 99;
        position: absolute;
        bottom: 50%;
        left: 50%;
        width: 32px;
        height: 32px;
        aspect-ratio: 1 / 1;
        flex-shrink: 0;
        background-color: var(--circle-color);
        transform: translate(-50%, 50%);
        border-radius: 50%;
    }
</style>

<script>
    import { gsap, ScrollTrigger } from "../lip/gsap";

    // ## Accordion
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.projects-list input[type="checkbox"]');

    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', () => {
            refreshAriaExpanded(checkbox);
            refreshScrollTrigger();
        });
    });

    function refreshScrollTrigger() {
        setTimeout(() => {
            ScrollTrigger.getById('curtain')?.refresh();
            ScrollTrigger.getById('testimonial-curtain')?.refresh();
            ScrollTrigger.getById('contact-section')?.refresh();
            ScrollTrigger.getById('refresh-area')?.refresh();
        }, 420);
    }

    window.addEventListener("resize", () => {
        refreshScrollTrigger();
        ScrollTrigger.getById("project-section")?.refresh();
    });

    function refreshAriaExpanded(checkbox: HTMLInputElement) {
        if (checkbox.checked) {
            checkboxes.forEach(other => {
                if (other !== checkbox) {
                    other.checked = false;
                    document.getElementById(`${other.id}-label`)?.setAttribute('aria-expanded', 'false');
                }
            });
        }
        const label = document.getElementById(`${checkbox.id}-label`);
        label?.setAttribute('aria-expanded', checkbox.checked ? 'true' : 'false');
    }

    const porjectsSection = document.querySelector<HTMLElement>(`[project-section]`);
    const projectHeadAera = Array.from(document.querySelectorAll<HTMLElement>(`[project-head-aera]`));
    const arrayProject = Array.from(document.querySelectorAll<HTMLElement>(`[single-project]`));
    const curtainBlack = document.querySelector<HTMLElement>(`[project-curtain-black]`);
    const whiteSkillCurtain = document.querySelector<HTMLElement>('[white-skill-curtain]');
    const projectsInputsArray: HTMLInputElement[] = gsap.utils.toArray(document.querySelectorAll('[project-checkbox]'));
    const circleCurtain = document.querySelector<HTMLElement>('[circle-curtain]');
    const projectsCardsArray: HTMLElement[] = gsap.utils.toArray(document.querySelectorAll('[project-card]'));

    type ColorScheme = {
        backgroundColor: string;
        textColor: string;
    }

    // ## Circle Growing Effect
    arrayProject.forEach((project, index) => {
        const label = projectsCardsArray[index];
        label?.addEventListener("click", () => {
            const currentColor = getComputedStyle(project).getPropertyValue('--project-color').trim();
            circleGrowing(currentColor);
        });
    });

    async function circleGrowing(currentColor: string) {
        if (!circleCurtain) return;
        const darkerColor = darkenColor(currentColor);
        circleCurtain.style.setProperty('--circle-color', darkerColor);
        const isAnyInputActive = await checkIsAkkodeonActive();
        setDarkThemeToInputs(isAnyInputActive);
        const newColorScheme: ColorScheme = {
            backgroundColor: isAnyInputActive ? darkerColor : '#fff',
            textColor: isAnyInputActive ? '#fff' : "#320105",
        };
        circleCurtain.style.setProperty('--circle-color', newColorScheme.backgroundColor);
        animationCircle(currentColor, newColorScheme);
    }

    function setDarkThemeToInputs(isAnyInputActive: boolean) {
        if (isAnyInputActive) {
            setTimeout(() => {
                projectsInputsArray.forEach((input, index) => {
                    if (input.checked) {
                        projectsCardsArray[index].classList.remove("dark-color-scheme");
                    } else {
                        projectsCardsArray[index].classList.add("dark-color-scheme");
                    }
                });
            }, 0);
        } else {
            projectsCardsArray.forEach(card => card.classList.remove("dark-color-scheme"));
        }
    }

    function animationCircle(oldColor: string, newColorScheme: ColorScheme) {
        gsap.killTweensOf(circleCurtain);
        gsap.set(circleCurtain, { width: 0, height: 0, opacity: 1 });

        const circleTl = gsap.timeline();
        circleTl
            .to(circleCurtain, {
                width: 3600,
                height: 3600,
                duration: 1.25,
                onStart: () => setNewColorScheme(oldColor, newColorScheme.textColor),
            })
            .to(circleCurtain, {
                onStart: () => setNewColorScheme(newColorScheme.backgroundColor, newColorScheme.textColor),
            }, "-=0.75")
            .to(circleCurtain, { opacity: 0, duration: 0.3 }, "+=0.3");
    }

    async function checkIsAkkodeonActive(): Promise<boolean> {
        await new Promise(resolve => setTimeout(resolve, 0));
        return projectsInputsArray.some(input => input.checked === true);
    }

    function setNewColorScheme(backgroundColor: string, textColor: string) {
        if (!whiteSkillCurtain || !porjectsSection) return;
        whiteSkillCurtain.style.setProperty('--background-color', backgroundColor);
        porjectsSection.style.setProperty('--background-color', backgroundColor);
        porjectsSection.style.setProperty('--text-color', textColor);
    }

    function darkenColor(currentColor: string) {
        const match = currentColor.match(/hsla?\((\d+),\s*([\d.]+)%,\s*([\d.]+)%/);
        if (match) {
            const h = Number(match[1]);
            const s = Number(match[2]);
            const l = Number(match[3]);
            return `hsla(${h - 5}, ${s + 34}%, ${l - 32}%, 100%)`;
        }
        return `hsla(230, 26%, 9%, 100%)`;
    }

    function resetSection() {
        gsap.killTweensOf(circleCurtain);
        gsap.set(circleCurtain, { width: 0, height: 0, opacity: 0, duration: 0 });
        setNewColorScheme("#fff", "#320105");
        setDarkThemeToInputs(false);
        projectsInputsArray.forEach(input => { input.checked = false; });
        refreshScrollTrigger();
    }

    // ## ScrollTrigger
    ScrollTrigger.create({
        id: "refresh-area",
        trigger: porjectsSection,
        start: "200px 50%",
        end: "bottom 75%",
        onLeaveBack: () => resetSection(),
    });

    gsap.set(curtainBlack, { y: "+=100vh" });

    gsap.timeline({
        scrollTrigger: {
            id: 'curtain',
            trigger: porjectsSection,
            start: 'bottom-=600 75%',
            end: 'bottom 50%',
            scrub: 1,
        }
    }).to(curtainBlack, { y: "-=200vh", ease: "power1.out" });

    gsap.timeline({
        scrollTrigger: {
            id: "project-section",
            trigger: porjectsSection,
            start: 'top 66%',
            end: '55% 75%',
            scrub: 1,
        }
    })
    .from(projectHeadAera, { y: "+=50px", opacity: 0, ease: "power1.out", stagger: 1 })
    .from(arrayProject, { y: "+=70px", opacity: 0, ease: "power1.out", stagger: 1 }, "+=2.5");
</script>
