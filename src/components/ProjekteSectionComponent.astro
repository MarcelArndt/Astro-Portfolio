</section>

<div class="project-preview" id="project-preview">
    <img id="project-preview-img" src="" alt="Projekt Vorschau" />
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .content-box{
        box-sizing: border-box;
        position: relative;
        z-index: 99;
        width: 100%;
        padding: 96px $inner-padding; 
    }

    .project-preview{
        box-sizing:border-box;
        padding: 1rem 2rem;
        position: fixed;
        top: 0;
        left: 0;
        width: clamp(300px, 24vw, 460px);
        aspect-ratio: 16 / 9;
        border-radius: 0.75rem;
        overflow: hidden;
        pointer-events: none;
        border: 1px solid #f6f6f6;
        z-index: 9999;
        opacity: 0;
        scale: 0.85;
        transition: opacity 0.2s ease-in-out, scale 0.2s ease-in-out;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        backdrop-filter: blur(4px);

        &.visible{
            opacity: 1;
            scale: 1;
        }

        img{
            display: flex;
            align-items: center;
            width: 100%;
            justify-content: center;
            height: 100%;
            object-fit: contain;
            object-position: center;
        }
    }

    .projects-list{
        list-style: none;

         li:not(:first-child){
            margin-top: 1.5rem;
        }

        p,ul,li{
            color:$font-color
        }

        input[type="checkbox"]{
            display: none;
        }

        h3{
            margin: 0.5rem 0px;
        }

        strong{
            font-weight: 300;
            font-size: clamp(1.5rem, 12vw, 3.25rem);
            display: block;
            margin: 0.5rem 0px 1rem 0px;
        }

        button{
            color: $font-white-color;
        }

        label {
            position: relative;
            width: 100%;
            font-size: $h4;
            font-weight: 300;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-sizing: border-box;
            padding: 0.75rem 2rem;
            border-radius: 1rem;
            border: 1px solid #ececec;
            gap: 1.5rem;

            &:hover{
                color:$main-color;
                cursor: pointer;
                background-color: #f6f6f6;
            }
        }

        span{
            display: flex;
            height: clamp(16px, 6vw, 32px);
            aspect-ratio: 1 / 1;
        }

        span > img{
            object-position: center;
            transform: rotate(-90deg);
            transition: transform 0.25s ease-in-out;
        }

        .button-box{
            display: flex;
            button:not(:first-child){
                margin-left: 1.25rem;
            }
        }

        .project-content-wrapper{
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.4s ease-in-out, opacity 0.3s ease-in-out;
            opacity: 0;
        }

        .project-content-inner{
            overflow: hidden;
            box-sizing: border-box;
            padding: 0rem 2rem;
            transition: padding 0.4s ease-in-out;

            p{
                max-width: 75ch;
            }

            p:not(:first-child){
                margin-bottom: 1.5rem;
            }
        }

        input[type="checkbox"]:checked ~ .project-content-wrapper{
            grid-template-rows: 1fr;
            opacity: 1;
        }

        input[type="checkbox"]:checked ~ label{
            background-color: #ececec;

            span > img{
                transform: rotate(90deg);
            }
        }

        input[type="checkbox"]:checked ~ .project-content-wrapper .project-content-inner{
            padding: 4rem 2rem;
        }

        .technology-list{
            list-style: none;
            display: flex;
            align-items: center;
            li:not(:first-child){
                margin-left: 1.5rem;
            }
            li{
                margin-top: 0px;
                filter: brightness(15%);
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100%;
            }
        }

        .thump-container{
            width: 100%;
            max-width: 678px;
            img{
                width: 100%;
                object-fit: contain;
                object-position: center;
            }
        }
    }




</style>

<script>
    // Accordion
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.projects-list input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', () => {
            if (checkbox.checked) {
                checkboxes.forEach(other => {
                    if (other !== checkbox) other.checked = false;
                });
            }
        });
    });

    // Cursor Preview
    const preview = document.getElementById('project-preview') as HTMLDivElement;
    const previewImg = document.getElementById('project-preview-img') as HTMLImageElement;
    const labels = document.querySelectorAll<HTMLLabelElement>('.projects-list label[data-preview]');
    
    const mouseOffsetX = 15;
    const mouseOffsetY = 15;
    let mouseX = 0;
    let mouseY = 0;
    let currentX = 0;
    let currentY = 0;
    let animating = false;

    function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
    }

    function animate() {
        currentX = lerp(currentX, mouseX, 0.7);
        currentY = lerp(currentY, mouseY, 0.7);
        preview.style.transform = `translate(${currentX}px, ${currentY}px)`;
        animating = true;
        requestAnimationFrame(animate);
    }

    document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX + mouseOffsetX;
        mouseY = e.clientY + mouseOffsetY;
        if (!animating) animate();
    });

    labels.forEach(label => {
        label.addEventListener('mouseenter', () => {
            const src = label.dataset.preview;
            if (src) previewImg.src = src;
            preview.classList.add('visible');
        });
        label.addEventListener('mouseleave', () => {
            preview.classList.remove('visible');
        });
    });
</script>