---
import SingleProjectComponent from "./SingleProjectComponent.astro"
import projects from "../data/projects.json"

import projectPictureOne from "../../public/assets/pictures/projects/project-one.jpg"
import projectPictureTwo from "../../public/assets/pictures/projects/project_two.jpg"
import projectPictureThree from "../../public/assets/pictures/projects/project_three.jpg"
import projectPictureFour from "../../public/assets/pictures/projects/project_four.jpg"
import { iconMap } from "../types/types-icon-map"

const previewImageMap: Record<string, string> = {
    "project-one": projectPictureOne.src,
    "project-two": projectPictureTwo.src,
    "project-three": projectPictureThree.src,
    "project-four": projectPictureFour.src,
};

---

<section >
    <div class="project-section-wrapper" project-section id="projects"> 
        <div class="content-box">
            <div>
                <p  project-head-aera>Dies ist eine Auswahl</p>
                <h2  project-head-aera>Meine Projekte</h2>
                <p class="sub-text"  project-head-aera>die meinen Weg sowie meine Leidenschaft für das Programmieren zeigt.</p>
            </div>

            <div>
                <ul class="projects-list">
                    {projects.map((project, index) => (
                        <li style={{ "--project-color": project.mainColor }} single-project>
                            <input type="checkbox" name={project.id} id={project.id} />
                            <label for={project.id} data-preview={previewImageMap[project.previewImage]}>
                                <div class="titel-box">
                                    <div class="cloumn-box">
                                        {project.label}
                                        <ul class="technology-list">
                                            {project.techstack.map( tech => (<li><img src={iconMap[tech].src}alt={iconMap[tech].alt} /></li>))}
                                        </ul>
                                        
                                    </div>
                                    <hr>
                                    <p>{project.descriptions[0]}</p>
                                </div>
                                <span><img src="./assets/icons/ui/goggle-mat-arrow-forward-ios.svg" /></span>

                            </label>
                            <div class="project-content-wrapper">
                                <div class="project-content-inner">
                                    <SingleProjectComponent
                                        subtitle={project.subtitle}
                                        title={project.title}
                                        descriptions={project.descriptions}
                                        previewImage={project.previewImage}
                                        techstack={project.techstack}
                                        demo={project.demo}
                                        github={project.github}
                                        mainColor={project.mainColor}
                                    />
                                </div>
                            </div>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </div>

    <div class="curtain-wrapper">
        <div class="black-box" project-curtain-black ></div>
    </div>
</section>

<div class="project-preview" id="project-preview">
    <img id="project-preview-img" src="" alt="Projekt Vorschau" />
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    section{
        position: relative;
    }

    .project-section-wrapper{
        box-sizing: border-box;
        padding-bottom: 460px;
    }

    p{
        color: $font-color;
        max-width: 75ch;
    }

    .sub-text{
        margin-bottom: 3rem;
    }

    .content-box{
        box-sizing: border-box;
        position: relative;
        z-index: 99;
        width: 100%;
        padding: 96px $inner-padding; 
    }

    .project-preview{
        box-sizing:border-box;
        padding: 1rem 2rem;
        position: fixed;
        top: 0;
        left: 0;
        width: clamp(300px, 24vw, 460px);
        aspect-ratio: 16 / 9;
        border-radius: 4px;
        overflow: hidden;
        pointer-events: none;
        border: 1px solid #f6f6f6;
        z-index: 9999;
        opacity: 0;
        scale: 0.85;
        transition: opacity 0.2s ease-in-out, scale 0.2s ease-in-out;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        backdrop-filter: blur(20px);

        &.visible{
            opacity: 1;
            scale: 1;
        }

        img{
            display: flex;
            align-items: center;
            width: 100%;
            justify-content: center;
            height: 100%;
            object-fit: contain;
            object-position: center;
        }
    }

    .projects-list{
        list-style: none;

         li:not(:first-child){
            margin-top: 1.5rem;
        }

        input[type="checkbox"]{
            display: none;
        }

        .titel-box{
            display: flex;
            width: 100%;

            hr{
                opacity: 0.5;
                margin: 0px 1.75rem; 

                @media screen and (max-width:767px) {
                    display: none;
                }
            }

            p{
                max-width: 60ch;
                box-sizing: border-box;
                padding-right: 3rem;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden; 
                opacity: 0.6;

                @media screen and (max-width:767px) {
                    display: none;
                }
            }
        }

        .cloumn-box{
            display: flex;
            flex-direction: column;
            align-items: start; 
            min-width: 260px;
            @media screen and (max-width:767px) {
                min-width: auto;
            }
        }

        label {
            position: relative;
            width: 100%;
            font-size: $h4;
            font-weight: 300;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-sizing: border-box;
            padding: 0.75rem 2rem;
            border-radius: 4px;
            border: 1px solid #f2f2f2;
            gap: 1.5rem;
            box-shadow: 4px 2px 4px rgba(0,0,0,0.04);

            &:hover{
                color: var(--project-color);
                cursor: pointer;
                background-color: #f6f6f6;
                border-color:#ececec;

                .titel-box{
                    p{
                        opacity: 1;
                    }

                }
            }
        }

        .technology-list{
            margin-top: 1rem;
            opacity: 0.5;

            li{
                width: 32px;
                height: 32px;

                img{
                    height: 100%;
                }
            }

            li:not(:first-child){
                margin-left: 1rem;
            }
            
        }

        span{
            display: flex;
            height: clamp(16px, 6vw, 32px);
            aspect-ratio: 1 / 1;
        }

        span > img{
            object-position: center;
            transform: rotate(-90deg);
            transition: transform 0.25s ease-in-out;
        }


        .project-content-wrapper{
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.4s ease-in-out, opacity 0.3s ease-in-out;
            opacity: 0;
        }

        .project-content-inner{
            overflow: hidden;
            box-sizing: border-box;
            padding: 0rem 2rem;
            transition: padding 0.4s ease-in-out;

            p{
                max-width: 75ch;
            }

            p:not(:first-child){
                margin-bottom: 1.5rem;
            }
        }

        input[type="checkbox"]:checked ~ .project-content-wrapper{
            grid-template-rows: 1fr;
            opacity: 1;
        }

        input[type="checkbox"]:checked ~ label{
            background-color: #ececec;

            span > img{
                transform: rotate(90deg);
            }
        }

        input[type="checkbox"]:checked ~ .project-content-wrapper .project-content-inner{
            padding: 4rem 2rem;
        }
    }

    .curtain-wrapper{

        position: absolute;
        top: -500px;
        left: 0px;
        width: 100%;
        height: calc(100% + 500px);
        overflow: hidden;
        }

    .black-box{
        z-index: 222;
        position: absolute;
        bottom: calc(-100% - 300px);
        height: 100%;
        width: 100%;
        background-color: $grey-background;

        &::before{
        content: "";
        position: absolute;
        top: -24%;
        right: 0px;
        width: 200%;
        height: 100%;
        rotate: 6deg;
        background-color: $grey-background;;
    }
    }
</style>

<script>

    // ## Accordion
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.projects-list input[type="checkbox"]');
    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', () => {
            if (checkbox.checked) {
                checkboxes.forEach(other => {
                    if (other !== checkbox) other.checked = false;
                });
            }
            // Nur den Vorhang-Trigger neu berechnen, tlContent bleibt unangetastet
            setTimeout(() => {
                ScrollTrigger.getById('curtain')?.refresh();
            }, 420); // nach der CSS-Transition (0.4s)
        });
    });

    // ## Cursor Preview
    const preview = document.getElementById('project-preview') as HTMLDivElement;
    const previewImg = document.getElementById('project-preview-img') as HTMLImageElement;
    const labels = document.querySelectorAll<HTMLLabelElement>('.projects-list label[data-preview]');

    const mouseOffsetX = 15;
    const mouseOffsetY = 15;
    let mouseX = 0;
    let mouseY = 0;
    let currentX = 0;
    let currentY = 0;
    let animating = false;


    function lerp(currentValue: number, targetValue: number, time: number) {
        return currentValue + (targetValue - currentValue) * time;
    }

    function checkForMobilDevice():boolean{
        return window.matchMedia('(hover: none) and (pointer: coarse)').matches
    }

    function animate() {
        if (checkForMobilDevice()) return;
        currentX = lerp(currentX, mouseX, 0.7);
        currentY = lerp(currentY, mouseY, 0.7);
        preview.style.transform = `translate(${currentX}px, ${currentY}px)`;
        animating = true;
        requestAnimationFrame(animate);
    }

    document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX + mouseOffsetX;
        mouseY = e.clientY + mouseOffsetY;
        if (!animating) animate();
    });

    labels.forEach(label => {
        label.addEventListener('mouseenter', () => {
            if (checkForMobilDevice()) return;
            const src = label.dataset.preview;
            if (src) previewImg.src = src;
            preview.classList.add('visible');
        });
        label.addEventListener('mouseleave', () => {
            preview.classList.remove('visible');
        });
    });

    // ## GSAP Animation
        import { gsap, ScrollTrigger } from "../lip/gsap";
        const porjectsSection = document.querySelector<HTMLElement>(`[project-section]`);
        const projectHeadAera = Array.from(document.querySelectorAll<HTMLElement>(`[project-head-aera]`));
        const arrayProject = Array.from(document.querySelectorAll<HTMLElement>(`[single-project]`));
        const curtainBlack = document.querySelector<HTMLElement>(`[project-curtain-black]`);


        gsap.set(curtainBlack,{
            y:"+=100vh",
        });

        const tlcurtainBlack = gsap.timeline({
        scrollTrigger: {
            id: 'curtain',
            trigger: porjectsSection,
            start: '81% bottom',
            end: 'bottom 75%',
            scrub: 1,
        } });

        tlcurtainBlack.to(curtainBlack,{
             y:"-=200vh",
             ease: "power1.out",
        })

        const tlContent = gsap.timeline({
        scrollTrigger: {
            trigger: porjectsSection,
            start: 'top 66%',
            end: '55% 75%',
            scrub: 1,
        } });

        tlContent
        .from(projectHeadAera,{
            y:"+=50px",
            opacity:0,
            ease: "power1.out",
            stagger:1,
        })
        .from(arrayProject,{
            y:"+=70px",
            opacity:0,
            ease: "power1.out",
            stagger:1,  
        },"+=2.5")





</script>