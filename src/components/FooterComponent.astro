---
import Logo from "../../public/assets/pictures/logo.svg"
---
<footer>

    <div class="main-footer-wrapper">
        <div class="logo">
            <a href="/#start"><img loading="lazy" src={Logo.src} alt="logo"></a>
            <p>Design (c) by Marcel Arndt</p>
        </div>
        <div class="nav-box">
            <nav class="footer-nav">
                <p>Navigation:</p>
                <ul>
                    <li><a href="/#start">Startseite</a></li>
                    <li><a href="/#about_me">Über Mich</a></li>
                    <li><a href="/#skills">Meine Skills</a></li>
                    <li><a href="/#projects">Projekte</a></li>
                    <li><a href="/#testimonial">Testimonial</a></li>
                    <li><a href="/#contact">Kontakt</a></li>
                </ul>
            </nav>

            <nav class="footer-nav">
                <p>Social:</p>
                <ul>
                    <li><a href="mailto:info@arndt-macrel.de">E-Mail</a></li>
                    <li><a target="_blank" href="https://github.com/MarcelArndt">Git Hub</a></li>
                    <li><a target="_blank" href="https://linkedin.com/in/profil-marcel-arndt">Linked In</a></li>
                </ul>
            </nav>
        </div>
    </div>

    <div class="secondary-footer">
        <hr>
        <div class="secondary-footer-wrapper">
            <p>© 2026 Marcel Arndt - Alle Rechte vorbehalten.</p>
        
            <nav class="data-protection-nav">
                <ul>
                    <li><a href="/#start">Startseite</a></li>
                    <li><a href="/imprint">Impressum</a></li>
                    <li><a href="/data-protection">Datenschutz</a></li>
                </ul>
            </nav>
    </div>
    <nav class="social-nav"></nav>
    </div>
</footer>

<style lang="scss">
    @use "../styles/index.scss" as *;
    
    footer{
        padding: 2rem $inner-padding;
        background-color: $footer-background;
        min-height: 280px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        justify-content: space-between;  
        
    }

    hr{
        width: 100%;
        border: none;
        border-top: 1px solid #fff;
        opacity: 0.25;
    }

    .main-footer-wrapper{
        padding-top: 2rem;
        display: flex;
        width: 100%;
        justify-content: space-between;
        margin-bottom: 2rem;

        @media screen and (max-width:723px) {
                flex-direction: column;
        }
    }

    .secondary-footer{
        display: flex;
        width: 100%;
        flex-direction: column;
    }

    .secondary-footer-wrapper{
        display: flex;
        width: 100%;
        align-items: center;
        justify-content: end;
        gap: 1rem;
        justify-content: space-between;
    
        p{
            color: #fff;
            opacity: 0.7;
            font-size: 1rem;
        }

        @media screen and (max-width:990px) {
            flex-direction: column;
            justify-content: center;
            p{
                width: 100%;
                text-align: center;
            }
        }
    }

    .data-protection-nav{
        ul{
            list-style: none;
            font-size: 1rem;
            gap: 3rem;
            display: flex;
            width: max-content;

            li:not(:first-child){
                position: relative;
                width: 100%;
                height: 100%;
                &::before{
                    content: "|";
                    color: #ffffff;
                    font-size: 1rem;
                    width: 100%;
                    height: 100%;
                    position: absolute;
                    left: -1.5rem;
                    top: 0px;
                    border: #fff;
                    opacity: 0.7;
                }
            }

             a{
                color: #ffffff;
                text-decoration: none;
                position: relative;
                opacity: 0.7;
                transition: opacity 0.25s ease-in-out, color 0.25s ease-in-out;

                &:hover{
                    scale:1.2;
                    color: $main-color;
                    opacity: 1;
                }
            }

            @media screen and (max-width:600px) {

                gap: clamp(1.5rem, 6vw, 2rem);
                display: flex;
                justify-content: center;
                align-items: center;
                margin-top: 1rem;
                flex-wrap: wrap;

                li{
                    width: max-content;
                    display: flex;
                    justify-content: center;
                }

                li:not(:first-child){
                    width: max-content;
                    &::before{
                content: "";
                color: transparent;
                font-size: 0;
                width: 0;
                height: 0;
                position: absolute;
                left: -1.5rem;
                top: 0px;
                }
                }
            }
        }
     }

    .logo{
        width: max-content;
        display: flex;
        flex-direction: column;
        justify-content: start;

        p{
            color: #fff;
            font-size: 1.275rem;
        }

        @media screen and (max-width:723px) {
            width: 100%;
            align-items: center;
            justify-content: center;

            a{
                display: flex;
                align-items: center;
                justify-content: center;
                object-position: center center;
                
            }

            img{
               
            }
        }
    }

    .nav-box{
        display: flex;
        gap: 6rem;

         @media screen and (max-width:723px) {
            align-items: center;
            flex-direction: column;
            gap: 0rem;
            margin-top: 2rem;
         }
    }

    .footer-nav{
        p{
            font-size: $font-size-100;
        }

        ul{
            list-style: none;
        }

        a{
            font-size: $font-size-100;
            color: #fff;
            text-decoration: none;
            opacity: 0.7;
            transition: opacity 0.25s ease-in-out, color 0.25s ease-in-out;

            &:hover{
                color: $main-color;
                opacity: 1;
            }
        }

        li{
            margin: 0.75rem 0rem;
        }

        @media screen and (max-width:723px) {
            margin-top: 2rem;

            p{
                text-align: center;
            }
            ul{
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                row-gap: 0rem;
                text-align: center;
                justify-content: center;
            }

             li{
                text-align: center;
             }
        }
    }
</style>