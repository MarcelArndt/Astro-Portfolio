---
interface cardContent{
    text: string;
    name: string;
    position: string;
}

const {text, name, position} = Astro.props


---



<div class="testimonial-card-wrapper">
    <div class="text">
        <p>
            <span>&quot;</span>
            {text}
            <span>&quot;</span>
        </p>

    </div>
    <div class="info-wrapper">
        <p class="name"><span>—</span>
       {name}
        </p>
        <p class="position-title">
            {position}
        </p>
    </div>
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .testimonial-card-wrapper{
        box-sizing: border-box;
        padding: 1.5rem;
        width: 342px;
        height: 280px;
        background-color: #171622;
        border: 1px solid #24283A;
        border-radius: 6px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 2px 4px 4px rgba(0, 0, 0,0.25);

        p{
            font-size: 1.125rem;
            line-height: 1.75rem;
        }
    }

    .position-title{
        opacity: 0.7;
    }

    .text{
        font-style: italic;

        span{
            font-weight: 900;
            line-height: 1.75rem;
        }
    }

</style>