---
interface cardContent{
    text: string;
    name: string;
    position: string;
    cardMaxWidth:number;
    cardMinWidth:number;
}

const {text, name, position, cardMaxWidth, cardMinWidth} = Astro.props as cardContent
---

<div testimoinal-card class="testimonial-card-wrapper" style={{"--card-max-width": cardMaxWidth + "px", "--card-min-width": cardMinWidth + "px"}} id="testimonial">
     <div class="quotes-icon"><img loading="lazy" src="./assets/icons/social/quotes.svg" alt=""></div>
    <div class="text">
        <p>
            <span>&quot;</span>
            {text}
            <span>&quot;</span>
        </p>

    </div>
    <hr>
    <div class="info-wrapper">
        <p class="name"><span>—</span>
       {name}
        </p>
        <p class="position-title">
            {position}
        </p>
    </div>
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .testimonial-card-wrapper{
        box-sizing: border-box;
        padding: clamp(2.25rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2rem) 1.5rem;
        width: clamp(var(--card-min-width), 48vw, var(--card-max-width));
        height: 100%;
        background-color: #171622;
        border: 1px solid #24283A;
        border-radius: 6px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 2px 4px 4px rgba(0, 0, 0,0.25);
        position: relative;

        p{
            font-size: clamp(1.125rem, 3vw, 1.5rem);
            line-height: clamp(1.75rem, 12vw, 2.125rem);
        }
    }
    
    hr{

        height: 1px;
        border: none;
        background-color: #fff;
        opacity: 1;
        height: clamp(1rem, 3vw, 3rem);
        margin-block-start: 0em;
        margin-block-end: 0em;
    }

    .position-title{
        opacity: 0.7;
    }

    .text{
        font-style: italic;

        span{
            font-weight: 900;
            line-height: 1.75rem;
        }
    }

    .quotes-icon{
        user-select: none;
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        opacity: 0.075;

        img{
            user-select: none;
        }
    }

</style>