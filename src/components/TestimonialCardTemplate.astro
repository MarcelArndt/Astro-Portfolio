---
interface cardContent{
    text: string;
    name: string;
    position: string;
    cardMaxWidth:number;
    cardMinWidth:number;
}

const {text, name, position, cardMaxWidth, cardMinWidth} = Astro.props as cardContent
---

<div class="testimonial-card-wrapper" style={{"--card-max-width": cardMaxWidth + "px", "--card-min-width": cardMinWidth + "px"}} id="testimonial">
     <div class="quotes-icon"><img loading="lazy" src="./assets/icons/social/quotes.svg" alt=""></div>
    <div class="text">
       
        <p>
            <span>&quot;</span>
            {text}
            <span>&quot;</span>
        </p>

    </div>
    <div class="info-wrapper">
        <p class="name"><span>—</span>
       {name}
        </p>
        <p class="position-title">
            {position}
        </p>
    </div>
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .testimonial-card-wrapper{
        box-sizing: border-box;
        padding: 2.5rem 1.5rem 1.5rem;
        width: clamp(var(--card-min-width), 32vw, var(--card-max-width));
        height: 280px;
        background-color: #171622;
        border: 1px solid #24283A;
        border-radius: 6px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 2px 4px 4px rgba(0, 0, 0,0.25);
        position: relative;

        @media screen and (max-width:1000px) {
            height: 320px;
        }

        p{
            font-size: 1.125rem;
            line-height: 1.75rem;
        }
    }

    .position-title{
        opacity: 0.7;
    }

    .text{
        font-style: italic;

        span{
            font-weight: 900;
            line-height: 1.75rem;
        }
    }

    .quotes-icon{
        user-select: none;
        position: absolute;
        bottom: 1.5rem;
        right: 1.5rem;
        opacity: 0.075;

        img{
            user-select: none;
        }
    }

</style>