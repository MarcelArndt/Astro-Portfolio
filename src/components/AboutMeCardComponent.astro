---
import statsIcon from "../../public/assets/icons/stats/infinity.svg"

interface Props {
    stats: string;
    text: string;
}

const {stats, text} = Astro.props;
---

<div about-me-stats-card class="about-me-card-wrapper">
    <div class="about-me-card-content-wrapper">
        {stats === "infinity" ? <div class="infinity-icon-container"><img src={statsIcon.src} alt="infinity" loading="lazy"/></div> : <h3>{stats}</h3>}
        <p>{text}</p>
    </div>
</div>

<style lang="scss">
    @use "../styles/index.scss" as *;

    .about-me-card-wrapper{
        background-color: #fff;
        width: 100%;
        height: 100%;
        border-radius: 8px;
        box-shadow: 2px 8px 8px rgba(0,0,0,0.125);

        .about-me-card-content-wrapper{
            container-type: inline-size;
            height: 100%;
            width: 100%;
            padding: 3rem clamp(1.75rem, 3vw, 3rem);
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: scale 0.25s ease-in-out;
            &:hover{
                scale: 1.01;
                h3{
                  color: $button-color-hover;  
                }

                img{
                    filter: brightness(0) saturate(100%) invert(71%) sepia(89%) saturate(411%) hue-rotate(83deg) brightness(94%) contrast(92%);
                }
            }
        }

        h3{
            font-size: clamp(3rem, 4vw, 5.5rem);
            font-weight: 600;
            color: $main-color;
            transition: color 0.25s ease-in-out;
        }
        

        .infinity-icon-container{
            display: flex;
            align-items: end;
            margin-bottom: 1rem;
            height: 100%;
            align-items: center;
        }

        img {
            height: clamp(1.125rem, 6vw, 2.5rem);
            object-position: left center;
            display: flex;
            justify-content: start;
            transition: filter 0.25s ease-in-out;
        }

        p{
            color:$font-color;
        }

        @container (width < 350px) {
            align-items: center;
            justify-content: center;

             img{
                justify-content: center;
                width: 100%;
             }
             
            p{
                text-align: center;
            }

            h3{
              text-align: center;  
            }
        }
        
    }
</style>